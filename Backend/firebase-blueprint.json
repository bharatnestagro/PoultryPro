{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Details of a poultry farmer or admin",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["farmer", "admin", "manager", "sub-admin"] },
        "assignedManagerId": { "type": "string", "description": "UID of the manager assigned to this farmer" },
        "farmName": { "type": "string" },
        "address": { "type": "string" },
        "farmArea": { "type": "number", "description": "In acres" },
        "birdCapacity": { "type": "number" },
        "farmType": { "type": "string", "enum": ["Gavthi Farm", "Sonali Farm", "Broiler Farm", "Layer Farm"] },
        "walletBalance": { "type": "number", "description": "Current balance in farmer's main wallet (deposited)" },
        "rewardBalance": { "type": "number", "description": "Balance earned from challenges" },
        "savedAddresses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "farmName": { "type": "string" },
              "line1": { "type": "string" },
              "area": { "type": "string" },
              "locality": { "type": "string" },
              "district": { "type": "string" },
              "state": { "type": "string" },
              "pincode": { "type": "string" },
              "name": { "type": "string" },
              "mobile": { "type": "string" },
              "altMobile": { "type": "string" },
              "type": { "type": "string", "enum": ["Home", "Main Farm", "Secondary Farm", "Godown"] }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "ChallengePlan": {
      "title": "Challenge Plan",
      "description": "A challenge plan created by admin for farmers",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "cost": { "type": "number", "description": "Entrance fee for the challenge" },
        "durationDays": { "type": "number", "description": "Total days of challenge (e.g., 90)" },
        "dailyReward": { "type": "number", "description": "Reward amount per successful daily entry" },
        "penaltyRule": { "type": "string", "description": "Rule description (e.g., miss 1 day in week, lose full week reward)" },
        "minWithdrawalPerOrder": { "type": "number", "description": "Minimum wallet balance usage on a single order" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "cost", "durationDays", "dailyReward"]
    },
    "UserChallenge": {
      "title": "User Challenge Participation",
      "description": "Progress of a farmer in a challenge",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "challengeId": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Active", "Completed", "Failed"] },
        "dailyEntries": { 
          "type": "object", 
          "description": "Map of date string to boolean indicating if entry was made" 
        },
        "totalEarned": { "type": "number" },
        "lastProcessedDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "challengeId", "startDate", "status"]
    },
    "WalletTransaction": {
      "title": "Wallet Transaction",
      "description": "Credit or debit record for farmer's wallet",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number", "description": "Positive for credit, negative for debit" },
        "type": { "type": "string", "enum": ["Credit", "Debit"] },
        "source": { "type": "string", "enum": ["Challenge Reward", "Bonus", "Withdrawal", "Order Payment"] },
        "referenceId": { "type": "string", "description": "ID of related order or challenge record" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "source", "createdAt"]
    },
    "Flock": {
      "title": "Bird Flock",
      "description": "A batch of birds in the farm",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "breed": { "type": "string", "enum": ["Broiler", "Layer", "Sonali", "Gavthi"] },
        "placementDate": { "type": "string", "format": "date" },
        "initialCount": { "type": "number" },
        "currentCount": { "type": "number" },
        "totalMortality": { "type": "number" },
        "totalEggs": { "type": "number" },
        "daysCount": { "type": "number" },
        "currentFCR": { "type": "number" },
        "productionRate": { "type": "number" },
        "costPerBird": { "type": "number", "description": "Calculated production cost per bird" },
        "source": { "type": "string", "description": "Hatchery name" },
        "farmType": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Sold", "Archived"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "breed", "placementDate", "initialCount"]
    },
    "DailyLog": {
      "title": "Daily Farm Log",
      "description": "Daily records for a specific flock",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "flockId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "environment": {
          "type": "object",
          "properties": {
            "temperature": { "type": "number" },
            "humidity": { "type": "number" },
            "ventilation": { "type": "string" },
            "lightDuration": { "type": "number" },
            "ammoniaLevel": { "type": "string" }
          }
        },
        "consumption": {
          "type": "object",
          "properties": {
            "feedIntake": { "type": "number" },
            "feedType": { "type": "string" },
            "waterIntake": { "type": "number" },
            "fcr": { "type": "number" }
          }
        },
        "production": {
          "type": "object",
          "properties": {
            "avgWeight": { "type": "number" },
            "weightGain": { "type": "number" },
            "eggCount": { "type": "number" },
            "eggWeight": { "type": "number" },
            "badEggs": { "type": "number" },
            "eggQuality": { "type": "string" }
          }
        },
        "health": {
          "type": "object",
          "properties": {
            "vaccines": { "type": "string" },
            "vaccineDoses": { "type": "number" },
            "medicines": { "type": "string" },
            "medicineDoses": { "type": "number" },
            "symptoms": { "type": "string" },
            "mortality": { "type": "number" },
            "culling": { "type": "number" }
          }
        },
        "biosecurity": {
          "type": "object",
          "properties": {
            "cleaning": { "type": "boolean" },
            "disinfection": { "type": "boolean" },
            "visitors": { "type": "number" },
            "footbath": { "type": "boolean" }
          }
        },
        "alerts": {
          "type": "object",
          "properties": {
            "feedDrop": { "type": "boolean" },
            "mortalityIncrease": { "type": "boolean" },
            "eggDrop": { "type": "boolean" },
            "abnormalBehavior": { "type": "string" }
          }
        }
      },
      "required": ["userId", "flockId", "date"]
    },
    "MedicineStock": {
      "title": "Medicine Stock",
      "description": "Inventory of medicines and vaccines",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Medicine", "Vaccine"] },
        "quantity": { "type": "number" },
        "unit": { "type": "string", "enum": ["ml", "g", "vial", "tablet"] },
        "purchaseCost": { "type": "number", "description": "Total cost of purchase" },
        "expiryDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "type", "quantity", "unit"]
    },
    "FeedStock": {
      "title": "Feed Stock",
      "description": "Inventory of poultry feed",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Pre-Starter", "Starter", "Grower", "Finisher", "Layer Mash"] },
        "quantity": { "type": "number", "description": "In kg" },
        "purchaseCost": { "type": "number", "description": "Total cost of purchase" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "type", "quantity"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Income or expense entry",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner UID" },
        "type": { "type": "string", "enum": ["Income", "Expense"] },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "description", "date"]
    },
    "Order": {
      "title": "Order",
      "description": "Order placed by farmer for supplies",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "assignedManagerId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" },
              "unit": { "type": "string" },
              "variant": { "type": "string" }
            }
          }
        },
        "status": { "type": "string", "enum": ["Pending", "Received", "Processing", "Delivered", "Cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["Pending", "Paid", "Failed"] },
        "totalAmount": { "type": "number" },
        "deliveryAddress": { "type": "object" },
        "paymentMethod": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "status", "deliveryAddress", "paymentMethod"]
    },
    "ShopItem": {
      "title": "Shop Item",
      "description": "Product available for farmers to purchase",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number", "description": "Sale price" },
        "mrp": { "type": "number", "description": "Maximum Retail Price" },
        "discountPercentage": { "type": "number" },
        "unit": { "type": "string" },
        "purchaseCost": { "type": "number", "description": "Cost price for the admin/manager" },
        "managerId": { "type": "string", "description": "UID of the manager who owns this product instance. Null for admin products." },
        "isHeavy": { "type": "boolean", "description": "If true, item is too heavy/big for standard bike delivery" },
        "isLiveStock": { "type": "boolean", "description": "If true, item requires special transport like Railways" },
        "variants": { 
          "type": "array", 
          "items": { 
            "type": "object", 
            "properties": {
              "name": { "type": "string" },
              "price": { "type": "number" },
              "unit": { "type": "string" }
            }
          }
        },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "imageUrls": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number" },
        "reviews": { 
          "type": "array", 
          "items": { 
            "type": "object", 
            "properties": {
              "userName": { "type": "string" },
              "rating": { "type": "number" },
              "comment": { "type": "string" },
              "date": { "type": "string", "format": "date" }
            }
          }
        },
        "inStock": { "type": "boolean" },
        "stockQuantity": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "price", "unit"]
    },
    "ShopCategory": {
      "title": "Shop Category",
      "description": "Product categories for the shop",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "Cart": {
      "title": "User Cart",
      "description": "Current items in a user's shopping cart",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "updatedAt"]
    },
    "HatcheryBatch": {
      "title": "Hatchery Batch",
      "description": "Details of a batch of eggs being hatched",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "batchName": { "type": "string" },
        "eggsSet": { "type": "number" },
        "setDate": { "type": "string", "format": "date" },
        "expectedHatchDate": { "type": "string", "format": "date" },
        "actualHatchDate": { "type": "string", "format": "date" },
        "chicksHatched": { "type": "number" },
        "gradeA": { "type": "number" },
        "gradeB": { "type": "number" },
        "mortality": { "type": "number" },
        "hatchability": { "type": "number", "description": "Percentage of eggs that hatched" },
        "status": { "type": "string", "enum": ["Incubating", "Hatched", "Cancelled"] },
        "notes": { "type": "string" },
        "cost": { "type": "number", "description": "Total cost of setting this batch" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "batchName", "eggsSet", "setDate"]
    },
    "ManagerPayment": {
      "title": "Manager Payment",
      "description": "Financial record of payments made to field managers",
      "type": "object",
      "properties": {
        "managerId": { "type": "string" },
        "managerName": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Paid", "Processing", "Pending"] },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["managerId", "amount", "status", "date"]
    },
    "ManagerCommission": {
      "title": "Manager Product Commission",
      "description": "Per-product commission settings for a specific manager",
      "type": "object",
      "properties": {
        "managerId": { "type": "string" },
        "managerName": { "type": "string" },
        "productCommissions": { 
          "type": "object", 
          "description": "Map of productId to commission amount in ₹" 
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["managerId", "productCommissions"]
    },
    "SystemAlert": {
      "title": "System Alert",
      "description": "Smart alerts and broadcast messages for farmers",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "target": { "type": "string", "enum": ["All", "Gavthi Farm", "Sonali Farm", "Broiler Farm", "Layer Farm"] },
        "condition": { "type": "string" },
        "treatment": { "type": "string" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "type": { "type": "string" },
        "active": { "type": "boolean" },
        "isAuto": { "type": "boolean" },
        "sourceLogId": { "type": "string" },
        "viewedBy": { "type": "array", "items": { "type": "string" }, "description": "UIDs of farmers who have seen this" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "target", "priority"]
    },
    "AlertRule": {
      "title": "Alert Rule",
      "description": "Natural language logic for auto-alerts",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logic": { "type": "string" },
        "priority": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string" }
      }
    },
    "Task": {
      "title": "Task / Schedule",
      "description": "Scheduled activities like vaccination or medicine for a farmer",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Farmer UID" },
        "creatorId": { "type": "string", "description": "UID of the person who created the task" },
        "creatorType": { "type": "string", "enum": ["Farmer", "Manager", "Admin"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["Vaccination", "Medicine", "Feed", "Maintenance", "Other"] },
        "scheduledDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Pending", "Completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "creatorId", "creatorType", "title", "scheduledDate", "status"]
    },
    "EggLog": {
      "title": "Egg Production Log",
      "description": "Daily egg collection and cost analysis",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "flockId": { "type": "string", "description": "Linked flock for this egg log" },
        "date": { "type": "string", "format": "date" },
        "totalEggs": { "type": "number" },
        "goodEggs": { "type": "number" },
        "badEggs": { "type": "number" },
        "feedConsumptionKg": { "type": "number" },
        "feedCostPerKg": { "type": "number" },
        "medicineCost": { "type": "number" },
        "labourCost": { "type": "number" },
        "birdCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "totalEggs", "birdCount"]
    },
    "EggSale": {
      "title": "Egg Sale Record",
      "description": "Retail or bulk egg sale entry",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "flockId": { "type": "string", "description": "Optional linked flock for this egg sale" },
        "saleDate": { "type": "string", "format": "date" },
        "eggCount": { "type": "number" },
        "sellingRate": { "type": "number" },
        "costPerEgg": { "type": "number" },
        "totalPrice": { "type": "number" },
        "totalCost": { "type": "number" },
        "profit": { "type": "number" },
        "buyerName": { "type": "string" },
        "buyerContact": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "saleDate", "eggCount", "sellingRate"]
    },
    "Contact": {
      "title": "Contact",
      "description": "Information about a business contact",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["Buyer", "Supplier", "Labor", "Vet", "Other"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "phone", "role"]
    },
    "LearningCategory": {
      "title": "Learning Category",
      "description": "Categories for grouping educational videos",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "LearningVideo": {
      "title": "Learning Video",
      "description": "Educational video for farmers",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "videoUrl": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "categoryId": { "type": "string", "description": "ID of the category this video belongs to" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "videoUrl", "createdAt"]
    },
    "VideoAnalytics": {
      "title": "Video Analytics",
      "description": "Tracking how farmers watch educational videos",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "videoId": { "type": "string" },
        "videoTitle": { "type": "string" },
        "status": { "type": "string", "enum": ["Partial", "Completed"] },
        "watchTime": { "type": "number", "description": "Total seconds watched" },
        "totalDuration": { "type": "number", "description": "Total duration of video in seconds" },
        "playCount": { "type": "number" },
        "lastWatchedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "videoId", "watchTime"]
    }
  },
  "firestore": {
    "/learningCategories/{categoryId}": {
      "schema": "LearningCategory",
      "description": "Categories for learning content"
    },
    "/learningVideos/{videoId}": {
      "schema": "LearningVideo",
      "description": "Educational videos"
    },
    "/videoAnalytics/{analyticsId}": {
      "schema": "VideoAnalytics",
      "description": "Farmer engagement records for videos"
    },
    "/eggSales/{saleId}": {
      "schema": "EggSale",
      "description": "Egg sales records"
    },
    "/contacts/{contactId}": {
      "schema": "Contact",
      "description": "Records of buyers, suppliers, and other farm contacts"
    },
    "/alertRules/{ruleId}": {
      "schema": "AlertRule",
      "description": "Dynamic logic rules for AI evaluation"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Farmer tasks and schedules"
    },
    "/eggLogs/{logId}": {
      "schema": "EggLog",
      "description": "Daily egg production and costing records"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/flocks/{flockId}": {
      "schema": "Flock",
      "description": "Bird flock documents"
    },
    "/dailyLogs/{logId}": {
      "schema": "DailyLog",
      "description": "Daily farm records"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Income/expense documents"
    },
    "/medicineStock/{stockId}": {
      "schema": "MedicineStock",
      "description": "Medicine inventory"
    },
    "/feedStock/{stockId}": {
      "schema": "FeedStock",
      "description": "Feed inventory"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Supply orders"
    },
    "/shopItems/{itemId}": {
      "schema": "ShopItem",
      "description": "Products for sale"
    },
