rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isBharatAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "bharatnestagro@gmail.com" ||
         request.auth.uid == "OQb1NF7095Qep0tLoijpSZNZRcl2");
    }

    function isAdmin() {
      return isBharatAdmin() || 
        (isAuthenticated() && (
          (request.auth.token.email == "bharatnestagro@gmail.com") ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")
        ));
    }

    function isManager() {
      return isAdmin() || 
        (isAuthenticated() && (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "manager")
        ));
    }

    function isAuth() {
      return request.auth != null;
    }

    function isUserOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.role in ['farmer', 'admin', 'manager'] &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.size() > 0;
    }

    function isValidFlock(data) {
      return data.keys().hasAll(['userId', 'name', 'breed', 'placementDate', 'initialCount']) &&
             data.userId == request.auth.uid &&
             data.breed in ['Broiler', 'Layer', 'Sonali', 'Gavthi'] &&
             data.initialCount is number && data.initialCount >= 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('currentCount' in data) || data.currentCount is number) &&
             (!('totalMortality' in data) || data.totalMortality is number) &&
             (!('totalEggs' in data) || data.totalEggs is number) &&
             (!('daysCount' in data) || data.daysCount is number) &&
             (!('status' in data) || data.status in ['Active', 'Sold', 'Archived']);
    }

    function isValidDailyLog(data) {
      return data.keys().hasAll(['userId', 'flockId', 'date']) &&
             data.userId == request.auth.uid &&
             data.flockId is string &&
             data.date is string &&
             (!('consumption' in data) || (
               data.consumption is map &&
               (!('feedIntake' in data.consumption) || data.consumption.feedIntake is number)
             )) &&
             (!('production' in data) || (
               data.production is map &&
               (!('eggCount' in data.production) || data.production.eggCount is number)
             )) &&
             (!('health' in data) || (
               data.health is map &&
               (!('mortality' in data.health) || data.health.mortality is number)
             ));
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'type', 'amount', 'description', 'date']) &&
             data.userId == request.auth.uid &&
             data.type in ['Income', 'Expense'] &&
             data.amount is number && data.amount >= 0 &&
             data.description is string && data.description.size() < 500;
    }

    function isValidMedicineStock(data) {
      return data.keys().hasAll(['userId', 'name', 'type', 'quantity', 'unit']) &&
             data.userId == request.auth.uid &&
             data.type in ['Medicine', 'Vaccine'] &&
             data.quantity is number && data.quantity >= 0 &&
             data.name is string && data.name.size() < 100;
    }

    function isValidFeedStock(data) {
      return data.keys().hasAll(['userId', 'name', 'type', 'quantity']) &&
             data.userId == request.auth.uid &&
             data.type in ['Pre-Starter', 'Starter', 'Grower', 'Finisher', 'Layer Mash'] &&
             data.quantity is number && data.quantity >= 0 &&
             data.name is string && data.name.size() < 100;
    }

    function isValidShopItem(data) {
      return data.keys().hasAll(['name', 'category', 'price', 'unit']) &&
             data.category in ['Feed', 'Medicine', 'Chicks', 'Equipment'] &&
             data.price is number && data.price >= 0 &&
             data.name is string && data.name.size() < 200;
    }

    function isValidManagerPayment(data) {
      return data.keys().hasAll(['managerId', 'amount', 'status', 'date']) &&
             data.managerId is string &&
             data.amount is number &&
             data.status in ['Paid', 'Processing', 'Pending'] &&
             (!('description' in data) || data.description is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (request.resource.data.role == 'farmer' || isAdmin());
      allow update: if isAuthenticated() && (userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /flocks/{flockId} {
      allow read: if isAdmin() || isManager() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isManager() || (isAuthenticated() && (resource.data.userId == request.auth.uid));
      allow delete: if isAdmin() || (isAuthenticated() && (resource.data.userId == request.auth.uid));
    }

    match /transactions/{transactionId} {
      allow read: if isAdmin() || isManager() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || resource.data.farmerId == request.auth.uid));
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isManager() || (isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.farmerId == request.auth.uid));
      allow delete: if isAdmin() || (isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.farmerId == request.auth.uid));
    }

    match /dailyLogs/{logId} {
      allow read: if isAdmin() || isManager() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isManager() || (isAuthenticated() && (resource.data.userId == request.auth.uid));
      allow delete: if isAdmin() || (isAuthenticated() && (resource.data.userId == request.auth.uid));
    }

    match /medicineStock/{stockId} {
      allow read: if isAdmin() || isManager() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isManager() || (isAuthenticated() && (resource.data.userId == request.auth.uid));
      allow delete: if isAdmin() || (isAuthenticated() && (resource.data.userId == request.auth.uid));
    }

    match /feedStock/{stockId} {
      allow read: if isAdmin() || isManager() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isManager() || (isAuthenticated() && (resource.data.userId == request.auth.uid));
      allow delete: if isAdmin() || (isAuthenticated() && (resource.data.userId == request.auth.uid));
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || isManager() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isManager() || (isAuthenticated() && (resource.data.userId == request.auth.uid));
      allow delete: if isAdmin();
    }

    match /shopItems/{itemId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /carts/{userId} {
      allow read: if isAuthenticated() && (userId == request.auth.uid || isAdmin() || isManager());
      allow create, update, delete: if isAuthenticated() && (userId == request.auth.uid || isAdmin() || isManager());
    }

    match /deletedOrders/{orderId} {
      allow read, create, delete: if isAdmin();
    }

    match /deletedKeys/{keyId} {
      allow read, write: if isAdmin() || isManager();
    }

    match /managerPayments/{paymentId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.managerId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    match /managerCommissions/{managerId} {
      allow read: if isAuthenticated() && (isAdmin() || managerId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /hatcheryBatches/{batchId} {
      allow read: if isAdmin() || isManager() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
      allow create, update, delete: if isAdmin() || isManager() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
    }

    match /incubatorLogs/{logId} {
      allow read: if isAdmin() || isManager() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
      allow create, update, delete: if isAdmin() || isManager() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
    }

    match /system/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || request.auth.token.email == "bharatnestagro@gmail.com";
    }

    match /licensePlans/{planId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || request.auth.token.email == "bharatnestagro@gmail.com";
    }

    match /systemAlerts/{alertId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isAdmin() || isManager() || (request.resource.data.isAuto == true && request.resource.data.userId == request.auth.uid));
      allow update: if isAuthenticated() && (isAdmin() || isManager() || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewedBy'])));
      allow delete: if isAdmin() || isManager();
    }

    match /alertRules/{ruleId} {
      allow read, write: if isAdmin();
    }

    match /licenseKeys/{keyId} {
      allow read: if isAuthenticated();
      allow create: if isManager() || isAdmin() || (isAuthenticated() && request.resource.data.usedBy == request.auth.uid);
      allow update: if isAdmin() || isManager() || request.auth.token.email == "bharatnestagro@gmail.com" || (
        isAuthenticated() && 
        resource.data.status == 'Unused' &&
        request.resource.data.status == 'Active' &&
        request.resource.data.usedBy == request.auth.uid
      ) || (
        isAuthenticated() && 
        resource.data.usedBy == request.auth.uid &&
        request.resource.data.usedBy == request.auth.uid
      );
      allow delete: if isManager() || request.auth.token.email == "bharatnestagro@gmail.com";
    }
  }
}
